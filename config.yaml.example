# s3-ocr-mineru 配置文件示例
# 将此文件复制为 config.yaml 并根据实际环境修改

# ============================================================
# S3 存储桶配置（必填）
# ============================================================

# 源 S3 桶名称：存放待处理原始文件的桶
source_bucket: "my-source-bucket"

# 目标 S3 桶名称：存放 OCR 识别结果（Markdown 文件）的桶
target_bucket: "my-target-bucket"

# ============================================================
# AWS 区域配置
# ============================================================

# AWS 区域，默认为 us-east-1
aws_region: "us-east-1"

# ============================================================
# 文件前缀配置（可选）
# ============================================================

# 源文件前缀：只处理 source_bucket 中以此前缀开头的文件
# 留空则处理桶内所有文件
# 示例："documents/" 或 "2024/reports/"
source_prefix: ""

# 目标文件前缀：OCR 结果上传到 target_bucket 时添加的路径前缀
# 留空则保持与源文件相同的相对路径结构
# 示例："ocr-results/" 或 "processed/"
target_prefix: ""

# ============================================================
# 日志配置
# ============================================================

# 日志级别：DEBUG、INFO、WARNING、ERROR
# DEBUG   - 输出所有日志，包括详细调试信息
# INFO    - 输出正常运行信息（推荐生产环境使用）
# WARNING - 只输出警告和错误
# ERROR   - 只输出错误信息
log_level: "INFO"

# ============================================================
# MinerU OCR 引擎配置
# ============================================================

# MinerU 后端模式
# pipeline - 标准流水线模式（推荐，适合大多数场景）
# vlm-transformers - 基于视觉语言模型的模式（需要额外依赖）
mineru_backend: "pipeline"

# OCR 识别语言
# ch  - 中文（含中英混排，推荐中文文档使用）
# en  - 英文
# 更多语言代码请参考 MinerU 文档
mineru_lang: "ch"
